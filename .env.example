# =============================================================================
# BEACON COMMAND — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in required values.
# Variables marked [REQUIRED] must be set for the application to start.
# Variables marked [OPTIONAL] enable additional features when provided.
# =============================================================================

# --- Application -----------------------------------------------------------
APP_ENV=development                    # development | staging | production
APP_HOST=0.0.0.0                       # Bind address
APP_PORT=8000                          # Bind port
APP_PUBLIC_BASE_URL=                   # [OPTIONAL] Public URL for webhooks/links
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# --- Database --------------------------------------------------------------
# [REQUIRED] PostgreSQL with asyncpg driver for async operations
DATABASE_URL=postgresql+asyncpg://beacon:beacon@postgres:5432/beacon
# [REQUIRED] Sync driver for Alembic migrations
DATABASE_SYNC_URL=postgresql+psycopg://beacon:beacon@postgres:5432/beacon

# --- Redis -----------------------------------------------------------------
# [REQUIRED] Used for locks, caching, rate limiting, deduplication
REDIS_URL=redis://redis:6379/0

# --- Slack -----------------------------------------------------------------
# [REQUIRED] Bot token (xoxb-...) for posting messages, managing channels
#   Bot scopes: chat:write, channels:read, groups:read, users:read, commands
SLACK_BOT_TOKEN=
# [REQUIRED] Coordinator user token (xoxp-...) for Real-Time Search and
#   user-scoped actions. Beacon only ever sees what this coordinator can see.
#   Real-Time Search (assistant.search.context) user token scopes:
#     search:read.public   -> public channels the coordinator belongs to
#     search:read.private  -> private channels the coordinator belongs to
#     search:read.users    -> resolve author identities
#   NOTE: search:read.im / search:read.mpim are intentionally NOT requested —
#   Beacon does not read direct messages (see Responsible Deployment in README).
SLACK_COORDINATOR_USER_TOKEN=
# [REQUIRED] Signing secret for verifying Slack requests
SLACK_SIGNING_SECRET=
# [OPTIONAL] App-level token (xapp-...) for Socket Mode development
SLACK_APP_TOKEN=
# [OPTIONAL] Default channel for hazard alerts
SLACK_DEFAULT_ALERT_CHANNEL=
# [OPTIONAL] Channel for volunteer coordination
SLACK_VOLUNTEERS_CHANNEL=
# [OPTIONAL] Channel for operations coordination
SLACK_OPERATIONS_CHANNEL=
# Enable/disable App Home tab
SLACK_APP_HOME_ENABLED=true

# --- Slack Search (RTS) ---------------------------------------------------
# Base URL for Slack search API (defaults to https://slack.com/api)
SLACK_RTS_BASE_URL=https://slack.com/api
# Timeout for search requests in seconds
SLACK_RTS_TIMEOUT_SECONDS=20

# --- LLM Provider ----------------------------------------------------------
# [REQUIRED] Active LLM provider: gemini | openai
LLM_PROVIDER=gemini
# [OPTIONAL] Override default model name
LLM_MODEL=
# Temperature for LLM generation (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1
# Maximum output tokens
LLM_MAX_OUTPUT_TOKENS=

# --- Gemini ----------------------------------------------------------------
# [REQUIRED if LLM_PROVIDER=gemini] Google AI API key
GEMINI_API_KEY=
# Model name (e.g., gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI ----------------------------------------------------------------
# [REQUIRED if LLM_PROVIDER=openai] OpenAI API key
OPENAI_API_KEY=
# [OPTIONAL] Custom base URL for OpenAI-compatible providers
OPENAI_BASE_URL=
# Model name (e.g., gpt-4o)
OPENAI_MODEL=gpt-4o

# --- Embeddings ------------------------------------------------------------
# Provider for embeddings: gemini | openai
EMBEDDING_PROVIDER=gemini
# Model name for embeddings
EMBEDDING_MODEL=text-embedding-004
# Embedding vector dimensions (must match pgvector column)
EMBEDDING_DIMENSIONS=768

# --- USGS Earthquake Feed --------------------------------------------------
# Real USGS GeoJSON feed URL
USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
# Polling interval in seconds
USGS_POLL_INTERVAL_SECONDS=60

# --- GDACS (Global Disaster Alert & Coordination System) -------------------
# GDACS RSS feed URL
GDACS_FEED_URL=https://www.gdacs.org/xml/rss.xml
# Polling interval in seconds
GDACS_POLL_INTERVAL_SECONDS=300

# --- Weather Provider -------------------------------------------------------
# Weather alert provider: nws (US National Weather Service, no key needed)
WEATHER_PROVIDER=nws
# [OPTIONAL] API key if provider requires one
WEATHER_API_KEY=
# [OPTIONAL] Base URL override
WEATHER_BASE_URL=

# --- Geocoding --------------------------------------------------------------
# Geocoding provider: nominatim (free, no key needed)
GEOCODING_PROVIDER=nominatim
# [OPTIONAL] API key if provider requires one
GEOCODING_API_KEY=
# [OPTIONAL] Base URL override
GEOCODING_BASE_URL=

# --- Routing ----------------------------------------------------------------
# Routing provider: osrm (free, no key needed)
ROUTING_PROVIDER=osrm
# [OPTIONAL] API key if provider requires one
ROUTING_API_KEY=
# [OPTIONAL] Base URL override
ROUTING_BASE_URL=

# --- Resource Provider ------------------------------------------------------
# Resource provider: postgres (PostgreSQL-backed organization registry)
RESOURCE_PROVIDER=postgres
# [OPTIONAL] External resource API key
RESOURCE_API_KEY=
# [OPTIONAL] External resource API base URL
RESOURCE_BASE_URL=

# --- LangSmith (optional tracing) ------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=beacon-command

# --- OpenTelemetry ----------------------------------------------------------
# [OPTIONAL] OTLP exporter endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=beacon-command

# --- MCP Server URLs -------------------------------------------------------
# URLs for MCP servers (started by the application or external)
MCP_HAZARD_SERVER_URL=http://localhost:8010
MCP_GEOSPATIAL_SERVER_URL=http://localhost:8011
MCP_RESOURCE_SERVER_URL=http://localhost:8012
MCP_OPERATIONS_SERVER_URL=http://localhost:8013
MCP_VERIFICATION_SERVER_URL=http://localhost:8014

# --- Agent Settings ---------------------------------------------------------
# Default tool invocation budget per mission
AGENT_DEFAULT_TOOL_BUDGET=12
# Default token budget per mission (empty = unlimited within model limits)
AGENT_DEFAULT_TOKEN_BUDGET=
# Default timeout per agent execution in seconds
AGENT_DEFAULT_TIMEOUT_SECONDS=120
# Maximum retries per mission
MISSION_MAX_RETRIES=3
# Maximum depth of mission dependency chain
MISSION_MAX_DEPTH=12
# Maximum parallel missions
MAX_PARALLEL_MISSIONS=6

# --- Hazard Thresholds ------------------------------------------------------
# Minimum earthquake magnitude to trigger processing
HAZARD_MIN_MAGNITUDE=4.0
# Minimum severity score (0-10) to trigger crisis creation
HAZARD_MIN_SEVERITY_SCORE=3.0
# Maximum earthquake depth in km for high-severity classification
HAZARD_MAX_DEPTH_KM=70.0
# Relevance threshold for operational attention (0.0-1.0)
HAZARD_RELEVANCE_THRESHOLD=0.3

# --- Epistemic Thresholds ---------------------------------------------------
# Minutes before a claim is considered stale
CLAIM_DEFAULT_FRESHNESS_MINUTES=60
# Confidence threshold for claim verification
CLAIM_VERIFICATION_THRESHOLD=0.7
# Threshold for flagging contradictions
CONTRADICTION_THRESHOLD=0.5
# Threshold for material change detection
MATERIAL_CHANGE_THRESHOLD=0.6
# Priority threshold for intelligence gap attention
INTELLIGENCE_GAP_PRIORITY_THRESHOLD=0.4

# --- Policy -----------------------------------------------------------------
# Require human approval for operational Slack writes
HUMAN_APPROVAL_REQUIRED_FOR_OPERATIONAL_WRITES=true
# Automatically create crisis command channels
AUTO_CREATE_CRISIS_CHANNEL=false
# Automatically create draft tasks from commitments
AUTO_CREATE_DRAFT_TASKS=false

# --- Prompts ----------------------------------------------------------------
# Version tag for prompt templates (for tracking/auditing)
PROMPT_VERSION=1
